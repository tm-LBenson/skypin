{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkyPin",
  "version": "0.1.0",
  "identifier": "com.lbenson.skypin",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
     {
       "label": "main",
       "title": "SkyPin",
       "width": 310,
       "height": 190,
       "decorations": false,
       "resizable": false,
       "transparent": true,
       "alwaysOnTop": true,
       "skipTaskbar": true,
       "visible": true
     }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
